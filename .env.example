# PostgreSQL (docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://documind:documind@localhost:5433/documind

# Redis (job queue for async ingestion; docker-compose maps host port 6380)
REDIS_URL=redis://localhost:6380

# External AI provider (embeddings + summaries)
OPENAI_API_KEY=sk-your-openai-key

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Query-embedding cache (Redis): repeated searches skip the OpenAI call
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL_SECONDS=86400

# AI summary
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_MAX_TOKENS=500
SUMMARY_MAX_INPUT_CHARS=12000

# AI agents (document-grounded answers + search-scope validation)
AGENT_MODEL=gpt-5.4-nano
AGENT_TIMEOUT_SECONDS=45
ANSWER_MAX_TOKENS=700

# Chunking
MAX_CHUNK_CHARS=1200

# Semantic search
SEARCH_TOP_K=10

# Local file storage
DATA_DIR=./data

# Hosts permitidos (IPs/CIDRs separados por coma); * = cualquier cliente
API_ALLOWED_HOSTS=*

# Optional: critical error notifications via Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
