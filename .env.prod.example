# Producción (VPS) — copiar a .env junto a docker-compose.prod.yml y completar.
# NO publiques este archivo; contiene secretos.

# --- Base de datos (usada por el contenedor postgres y la API) ---
POSTGRES_USER=documind
POSTGRES_PASSWORD=cambia-esto-por-una-clave-larga-y-aleatoria
POSTGRES_DB=documind

# --- OpenAI (embeddings + resúmenes + agentes) ---
OPENAI_API_KEY=sk-tu-clave-real-de-openai
SUMMARY_MODEL=gpt-4o-mini
AGENT_MODEL=gpt-5.4-nano

# --- Búsqueda semántica ---
SEARCH_TOP_K=10

# --- Exposición directa de la API (clientes externos sin pasar por el frontend) ---
# 0.0.0.0 = accesible desde fuera del servidor (HTTP plano; usa la ruta
# https://<dominio>/api para TLS). 127.0.0.1 = solo local.
API_BIND=0.0.0.0
API_PORT=8000

# Hosts permitidos: IPs y/o rangos CIDR separados por coma, p. ej.
# "203.0.113.5, 10.0.0.0/8". "*" = accesible desde cualquier cliente (defecto).
# Complementa (no sustituye) a la autenticación por X-API-Key.
API_ALLOWED_HOSTS=*

# --- Opcional: alertas de errores críticos ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
